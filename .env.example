# ── Solana connection ─────────────────────────────────────────────────────────
SOLANA_RPC=""               # your Solana RPC URL (e.g. from Helius, QuickNode)
PRIVATE_KEY=""              # base58 private key used to sign transactions
PUBLIC_KEY=""               # corresponding public key / wallet address

# ── Bot mode ──────────────────────────────────────────────────────────────────
BOT_MODE="COPY"             # "COPY" (live trading) | "SELLING" (liquidate all)

# ── Copy-trading settings ─────────────────────────────────────────────────────
COPY_WALLET=""              # wallet address to mirror
TRADE_TYPE="SAFE"           # "SAFE" (fixed buy, TP/SL) | "EXACT" (mirror exact amounts)
BUY_AMOUNT="0.01"           # SOL to spend per trade (SAFE mode only)
MAX_POSITIONS="10"          # maximum number of concurrent open positions

# ── Take-profit / Stop-loss (SAFE mode only) ──────────────────────────────────
TAKE_PROFIT="10"            # close when price is +X% above entry
STOP_LOSS="5"               # close when price is -X% below entry

# ── Trailing Stop Loss ────────────────────────────────────────────────────────
ENABLE_TRAILING_STOP=false          # true | false
TRAILING_STOP_DISTANCE=10.0         # trail distance below the peak price (%)
TRAILING_STOP_ACTIVATION=20.0       # minimum profit before trailing activates (%)

# ── Multi-buy ─────────────────────────────────────────────────────────────────
ENABLE_MULTI_BUY="false"    # true → allow repeated buys for the same mint

# ── DEX preference ────────────────────────────────────────────────────────────
PREFERRED_DEX=auto          # none | auto | pumpfun | meteora | raydium | moonshot | jupiter

# ── Execution ─────────────────────────────────────────────────────────────────
SLIPPAGE="20"               # slippage tolerance in percent
JITO_TIP="0.0005"           # Jito bundle tip in SOL
JITO_ENGINE="https://tokyo.mainnet.block-engine.jito.wtf/api/v1/transactions"

# ── Price checking ────────────────────────────────────────────────────────────
COINVERA_API=""             # Coinvera API key (https://coinvera.io)
PRICE_CHECK_DELAY="5000"    # how often to poll open-position prices (ms)

# ── Telegram notifications (optional) ────────────────────────────────────────
# Leave blank to disable. Get a token from @BotFather and your chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
